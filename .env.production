# Production build config, auto-loaded by `vite build` (not by `npm run dev`).
#
# VITE_SERVER_URL is the deployed game server the GitHub Pages client connects to.
# Deploy the server to Railway FIRST, generate a public domain, then replace the
# placeholder below with that domain. It MUST be wss:// (a secure HTTPS Pages page
# cannot open an insecure ws:// connection — the browser blocks it as mixed content).
#
# Example: VITE_SERVER_URL=wss://extreme-games-production.up.railway.app
VITE_SERVER_URL=wss://extremegames-production.up.railway.app
